{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/portal/bookings/[id]",
      "regex": "^/portal/bookings/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/portal/bookings/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/clients/[id]",
      "regex": "^/portal/clients/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/portal/clients/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/trips/[id]",
      "regex": "^/portal/trips/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/portal/trips/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/analytics",
      "regex": "^/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/analytics(?:/)?$"
    },
    {
      "page": "/bookings",
      "regex": "^/bookings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/bookings(?:/)?$"
    },
    {
      "page": "/clients",
      "regex": "^/clients(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/clients(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/portal/admin/sync-clients",
      "regex": "^/portal/admin/sync\\-clients(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/admin/sync\\-clients(?:/)?$"
    },
    {
      "page": "/portal/analytics",
      "regex": "^/portal/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/analytics(?:/)?$"
    },
    {
      "page": "/portal/auth/login",
      "regex": "^/portal/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/auth/login(?:/)?$"
    },
    {
      "page": "/portal/auth/logout",
      "regex": "^/portal/auth/logout(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/auth/logout(?:/)?$"
    },
    {
      "page": "/portal/auth/me",
      "regex": "^/portal/auth/me(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/auth/me(?:/)?$"
    },
    {
      "page": "/portal/bookings",
      "regex": "^/portal/bookings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/bookings(?:/)?$"
    },
    {
      "page": "/portal/clients",
      "regex": "^/portal/clients(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/clients(?:/)?$"
    },
    {
      "page": "/portal/trips",
      "regex": "^/portal/trips(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/trips(?:/)?$"
    },
    {
      "page": "/trips",
      "regex": "^/trips(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/trips(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
